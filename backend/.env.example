# ════════════════════════════════════════════════════════════════
# Chabua First Leaf — Backend
# Copy to .env and fill in real values. Never commit .env.
# ════════════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# ─── Supabase ──────────────────────────────────────────────────
# Project Settings → API → service_role (NOT anon)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook secret — pick any random string ≥32 chars and paste the same
# value in Razorpay Dashboard → Settings → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=

# ─── Resend (emails) ───────────────────────────────────────────
# Leave RESEND_API_KEY blank in dev — emails will log instead of send
RESEND_API_KEY=
RESEND_FROM_EMAIL=Chabua First Leaf <orders@chabuafirstleaf.com>

# ─── Shiprocket ────────────────────────────────────────────────
# Leave blank in dev — admin "mark as Shipped" still works,
# just skips actual shipment creation
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary