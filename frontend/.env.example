# Backend API origin
VITE_API_BASE_URL=http://localhost:5000

# Supabase — Project Settings → API → anon (NOT service_role)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=

# Razorpay — same Key ID as backend, NEVER the secret
VITE_RAZORPAY_KEY=

# Public site URL (used for SEO/OG tags)
VITE_SITE_URL=http://localhost:5173

# Comma-separated admin allow-list — controls /admin access
VITE_ADMIN_EMAILS=